spyce() -> void {
    int sum   = 0;
    int input = -1;
    say("Enter integers (0 to stop): \n");
    while (input != 0) {
        say("Enter a number: ");
        input = tofloat(listen());

        when (input > 0) {
            sum += input;
        }
    }
    say("Sum of positive integers: " + tostr(sum));
    giveback void;
}
