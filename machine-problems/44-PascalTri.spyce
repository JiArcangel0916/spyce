spyce() -> void {
	say("Enter number: ");
    int rows = toint(listen());

    when(rows < 0){
        say("Number cannot be a negative number");
        giveback void;
    }

    for(int i = 0; i < rows; i++){
		int val = 1;
        for(int s = 0; s < rows - i; s++){
            say(" ");
        }
        for(int j = 0; j <= i; j++){
            say(tostr(val) + " ");
			val = val * (i - j) / (j + 1);
        }
        say("\n");
    }

    giveback void;
}