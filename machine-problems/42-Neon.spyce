make isNeon(int n) -> bool {
	int sq = n * n;
	int sum = 0;
	int temp = sq;
	while(temp > 0){
		sum += temp % 10;
		temp = temp / 10;
	}
	when(sum == n){
		giveback true;
	}
	giveback false;
}

spyce() -> void {
	say("Enter num: ");
	int resp = toint(listen());

	when(isNeon(resp)){
		say(tostr(resp) + " is a neon number\n");
	} otherwise{
		say(tostr(resp) + " is NOT a neon number\n");
	}
	giveback void;
}