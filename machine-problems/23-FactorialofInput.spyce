make factorial(float n) -> float {
    when (n <= 1.0) { giveback 1.0; }
    giveback n * factorial(n - 1.0);
}

spyce() -> void {
    float n = 0.0;

    while (n <= 0.0) {
        say("Enter a positive number: \n");
        n = tofloat(listen());
        when (n <= 0.0) {
            say("Please enter a positive number! \n");
        }
    }

    float result = factorial(n);
    say(tostr(n) + "! = " + tostr(result));
    giveback;
}