spyce() -> void {
    float sum   = 0;
    float input = -1.00;
    say("Enter integers (0 to stop): \n");
    while (input != 0) {
        say("Enter a number: ");
        input = tofloat(listen());
        when (input > 0) {
            sum += input;
        }
    }
    say("Sum of positive integers: " + tostr(sum));
    giveback void;
}
