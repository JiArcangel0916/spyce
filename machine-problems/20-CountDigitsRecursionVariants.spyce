make countDigits(string numStr, int i) -> int { 
    int result = 0;
    when (i == len(numStr)) {
        giveback 0;
    }
    otherwise {
        result = 1 + countDigits(numStr, i + 1);
    }
    giveback result;
}

spyce() -> void {
    say("Input a number: ");
    int n = tofloat(listen());
	when(n < 0){
		n *= -1;
	}
    int count = countDigits(tostr(n), 0);
    say("The number of digits in the number is: " + tostr(count));
    giveback;
}