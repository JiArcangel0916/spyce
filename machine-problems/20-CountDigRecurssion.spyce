make countDigits(int n) -> int {
    when (n == 0) { giveback 0; }
    int result =  1 + countDigits(n / 10);
    giveback result;
}


spyce() -> void {
    say("Input a number: ");
    int n = toint(listen());

	when(n < 0){ n *= -1; }

    int count = countDigits(n);
    say("The number of digits in the number is : " + tostr(count));
    giveback void;
}
